{
  "name": "domain-health-checker",
  "version": "1.0.0",
  "description": "Query and output domains from AutoDNS API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "legacy": "node index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fallow": "fallow --format compact",
    "fallow:dead": "fallow dead-code --format compact",
    "fallow:dupes": "fallow dupes --format compact",
    "fallow:health": "fallow health --format compact --score",
    "fallow:audit": "fallow audit --gate new-only"
  },
  "keywords": [
    "autodns",
    "domains",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.7",
    "p-retry": "^7.1.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@vitest/ui": "^4.0.9",
    "eslint": "^9.39.1",
    "fallow": "^2.75.0",
    "globals": "^16.5.0",
    "vitest": "^4.0.9"
  }
}
